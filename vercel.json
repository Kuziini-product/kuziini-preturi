{
  "version": 2,
  "framework": null,
  "functions": {
    "api/search.py": { "maxDuration": 60 },
    "api/cron.py": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/cron", "destination": "/api/cron.py" },
    { "source": "/api/(.*)", "destination": "/api/search.py" }
  ],
  "crons": [
    {
      "path": "/api/cron?reset=1",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron?reset=1",
      "schedule": "0 15 * * *"
    }
  ]
}
