{
  "version": 2,
  "builds": [
    {
      "src": "api/search.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/search.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/search.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
